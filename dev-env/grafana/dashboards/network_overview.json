{
  "uid": "telecom-overview",
  "title": "Malleswaram Network Overview",
  "tags": ["telecom", "5g", "overview"],
  "timezone": "browser",
  "schemaVersion": 38,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1, "type": "stat", "title": "Total Connected UEs",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{"color":"green","value":null},{"color":"yellow","value":10000},{"color":"red","value":16000}] },
          "unit": "short" }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" },
      "targets": [{
        "refId": "A", "datasource": { "type": "influxdb", "uid": "${datasource}" },
        "query": "from(bucket: \"telecom_metrics\")\n  |> range(start: -2m)\n  |> filter(fn: (r) => r._measurement == \"cell_kpi\" and r._field == \"connected_ues\")\n  |> last()\n  |> sum()"
      }]
    },
    {
      "id": 2, "type": "stat", "title": "Active Cells",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "fieldConfig": {
        "defaults": { "color": { "mode": "fixed", "fixedColor": "blue" }, "unit": "short" }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "targets": [{
        "refId": "A", "datasource": { "type": "influxdb", "uid": "${datasource}" },
        "query": "from(bucket: \"telecom_metrics\")\n  |> range(start: -2m)\n  |> filter(fn: (r) => r._measurement == \"cell_kpi\" and r._field == \"connected_ues\")\n  |> last()\n  |> count()"
      }]
    },
    {
      "id": 3, "type": "stat", "title": "Avg DL Throughput (Mbps)",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{"color":"red","value":null},{"color":"yellow","value":500},{"color":"green","value":1000}] },
          "unit": "Mbps" }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "targets": [{
        "refId": "A", "datasource": { "type": "influxdb", "uid": "${datasource}" },
        "query": "from(bucket: \"telecom_metrics\")\n  |> range(start: -2m)\n  |> filter(fn: (r) => r._measurement == \"cell_kpi\" and r._field == \"dl_throughput_mbps\")\n  |> last()\n  |> mean()"
      }]
    },
    {
      "id": 4, "type": "stat", "title": "Avg SINR (dB)",
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{"color":"red","value":null},{"color":"yellow","value":5},{"color":"green","value":15}] },
          "unit": "dB" }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "targets": [{
        "refId": "A", "datasource": { "type": "influxdb", "uid": "${datasource}" },
        "query": "from(bucket: \"telecom_metrics\")\n  |> range(start: -2m)\n  |> filter(fn: (r) => r._measurement == \"cell_kpi\" and r._field == \"sinr_db\")\n  |> last()\n  |> mean()"
      }]
    },
    {
      "id": 5, "type": "stat", "title": "Overloaded Cells (PRB>85%)",
      "gridPos": { "x": 16, "y": 0, "w": 4, "h": 4 },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{"color":"green","value":null},{"color":"yellow","value":1},{"color":"red","value":5}] },
          "unit": "short" }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "targets": [{
        "refId": "A", "datasource": { "type": "influxdb", "uid": "${datasource}" },
        "query": "from(bucket: \"telecom_metrics\")\n  |> range(start: -2m)\n  |> filter(fn: (r) => r._measurement == \"cell_kpi\" and r._field == \"prb_dl_pct\")\n  |> last()\n  |> filter(fn: (r) => r._value > 85.0)\n  |> count()"
      }]
    },
    {
      "id": 6, "type": "stat", "title": "Total Network Power (kW)",
      "gridPos": { "x": 20, "y": 0, "w": 4, "h": 4 },
      "fieldConfig": {
        "defaults": { "unit": "kwatt",
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{"color":"green","value":null},{"color":"yellow","value":15},{"color":"red","value":25}] } }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "targets": [{
        "refId": "A", "datasource": { "type": "influxdb", "uid": "${datasource}" },
        "query": "from(bucket: \"telecom_metrics\")\n  |> range(start: -2m)\n  |> filter(fn: (r) => r._measurement == \"cell_kpi\" and r._field == \"power_w\")\n  |> last()\n  |> sum()\n  |> map(fn: (r) => ({r with _value: r._value / 1000.0}))"
      }]
    },
    {
      "id": 10, "type": "timeseries", "title": "Connected UEs Over Time (network total)",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "palette-classic" } } },
      "options": { "legend": { "calcs": ["lastNotNull","max"], "displayMode": "table", "placement": "bottom" } },
      "targets": [{
        "refId": "A", "datasource": { "type": "influxdb", "uid": "${datasource}" },
        "query": "from(bucket: \"telecom_metrics\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"cell_kpi\" and r._field == \"connected_ues\")\n  |> aggregateWindow(every: 1m, fn: sum)\n  |> yield(name: \"total_ues\")"
      }]
    },
    {
      "id": 11, "type": "timeseries", "title": "Avg PRB Utilization by Band",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": { "unit": "percent", "max": 100,
          "custom": { "lineWidth": 2 } }
      },
      "targets": [{
        "refId": "A", "datasource": { "type": "influxdb", "uid": "${datasource}" },
        "query": "from(bucket: \"telecom_metrics\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"cell_kpi\" and r._field == \"prb_dl_pct\")\n  |> aggregateWindow(every: 1m, fn: mean)\n  |> group(columns: [\"band\"])\n  |> yield(name: \"prb_by_band\")"
      }]
    },
    {
      "id": 20, "type": "timeseries", "title": "SINR Distribution Over Time",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "fieldConfig": { "defaults": { "unit": "dB" } },
      "targets": [{
        "refId": "A", "datasource": { "type": "influxdb", "uid": "${datasource}" },
        "query": "from(bucket: \"telecom_metrics\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"cell_kpi\" and r._field == \"sinr_db\")\n  |> aggregateWindow(every: 1m, fn: mean)\n  |> group(columns: [\"generation\"])\n  |> yield(name: \"sinr_by_gen\")"
      }]
    },
    {
      "id": 21, "type": "timeseries", "title": "Network Power Consumption (W)",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "fieldConfig": { "defaults": { "unit": "watt" } },
      "targets": [{
        "refId": "A", "datasource": { "type": "influxdb", "uid": "${datasource}" },
        "query": "from(bucket: \"telecom_metrics\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"cell_kpi\" and r._field == \"power_w\")\n  |> aggregateWindow(every: 1m, fn: sum)\n  |> yield(name: \"total_power\")"
      }]
    }
  ],
  "templating": {
    "list": [{
      "type": "datasource", "name": "datasource", "label": "Data Source",
      "query": "influxdb", "current": { "text": "InfluxDB-Telecom", "value": "InfluxDB-Telecom" }
    }]
  }
}
