INFLUXDB_ADMIN_USER=admin
INFLUXDB_ADMIN_PASSWORD=changeme
INFLUXDB_ORG=telecom
INFLUXDB_BUCKET=telecom_metrics
INFLUXDB_TOKEN=your-influxdb-token-here
GRAFANA_PASSWORD=changeme
LANGCHAIN_API_KEY=your-langsmith-api-key-here   # get from smith.langchain.com
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=telecom-automation

# ── LLM backend (pick one) ────────────────────────────────────────────────────

# Option A — Google Gemini (default, requires API key)
GOOGLE_API_KEY=your-google-api-key-here

# Option B — Claude CLI  (no API key needed — uses your local `claude` login)
# The orchestrator switches to Claude automatically when CLAUDE_CLI_PATH is set.
# The Dockerfile installs the claude binary at /usr/local/bin/claude.
# Your host ~/.claude credentials are mounted into the container automatically.
#
# To activate: uncomment the two lines below (and you can leave GOOGLE_API_KEY blank)
# CLAUDE_CLI_PATH=/usr/local/bin/claude
# ANTHROPIC_MODEL_NAME=sonnet
